PORT=8080
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
WAITLIST_EMAIL_DELIVERY=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
WAITLIST_EMAIL_FROM=NAIVAIDYA <waitlist@yourdomain.com>

# Optional SMTP delivery if WAITLIST_EMAIL_DELIVERY=smtp.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=NAIVAIDYA <your-email@gmail.com>

# Local-only option for development without a working email provider.
# Never use this in production.
# WAITLIST_EMAIL_DELIVERY=console
